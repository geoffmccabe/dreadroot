{
  // Cloudflare Workers (Static Assets) deploy config for the Vite SPA build.
  // `npx wrangler deploy` uploads ./dist as static assets; no Worker script.
  // not_found_handling=single-page-application serves index.html for client
  // routes (BrowserRouter) — replaces the Pages `_redirects` SPA hack.
  "name": "dreadroot",
  "compatibility_date": "2025-05-17",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
